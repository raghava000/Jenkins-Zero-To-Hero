pipeline {
    agent {
        docker {
            image 'abhishekf5/maven-abhishek-docker-agent:v1'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }
    parameters {
        string(name: 'action', defaultValue: 'apply', description: 'Apply or Destroy')
    }
    environment {
        // STRATEGIC MOVE: Replace these with your ACTUAL GCP Project and Static IPs
        project_id = 'your-gcp-project-id' 
        sonar_url  = 'http://10.148.0.3:9000' // Ensure this matches your Sonar VM Internal IP
    }
    stages {
        stage('Checkout') {
            steps {
                // Uses the 4th key we created: the Username/Password for Git
                checkout scm
            }
        }
        stage('Build and Test') {
            steps {
                sh 'mvn clean package'
            }
        }
        stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    // This will fail if Port 9000 isn't open in GCP Firewall
                    sh "mvn sonar:sonar -Dsonar.projectKey=spring-boot-app -Dsonar.host.url=${env.sonar_url} -Dsonar.login=${SONAR_TOKEN}"
                }
            }
        }
        stage('Build and Push Docker Image') {
            steps {
                script {
                    // Uses the JSON key credential for GCP Artifact Registry
                    withCredentials([usernamePassword(credentialsId: 'gcp-artifact-creds', passwordVariable: 'GCP_JSON_KEY', usernameVariable: 'GCP_USER')]) {
                        sh "echo '${GCP_JSON_KEY}' | docker login -u _json_key --password-stdin https://asia-south1-docker.pkg.dev"
                        sh "docker build -t asia-south1-docker.pkg.dev/${env.project_id}/ultimate-cicd/spring-boot-app:${env.BUILD_NUMBER} ."
                        sh "docker push asia-south1-docker.pkg.dev/${env.project_id}/ultimate-cicd/spring-boot-app:${env.BUILD_NUMBER}"
                    }
                }
            }
        }
        stage('Update Deployment File') {
            steps {
                withCredentials([string(credentialsId: 'github-pat', variable: 'GITHUB_TOKEN')]) {
                    // Update the manifest file in your repo with the new image tag
                    sh "sed -i 's|image:.*|image: asia-south1-docker.pkg.dev/${env.project_id}/ultimate-cicd/spring-boot-app:${env.BUILD_NUMBER}|' k8s/deployment.yaml"
                    sh 'git config user.email "raghava_mutharaju111@gmail.com"'
                    sh 'git config user.name "Raghava"'
                    sh "git add k8s/deployment.yaml"
                    sh "git commit -m 'Update image tag to ${env.BUILD_NUMBER}'"
                    sh "git push https://${GITHUB_TOKEN}@github.com/raghava000/Jenkins-Zero-To-Hero.git main"
                }
            }
        }
    }
}
